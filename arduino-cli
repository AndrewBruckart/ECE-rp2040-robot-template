#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONFIG_FILE="$ROOT_DIR/arduino-cli.yaml"

if command -v arduino-cli >/dev/null 2>&1; then
  CLI="arduino-cli"
elif [ -x "/Applications/Arduino IDE.app/Contents/Resources/app/lib/backend/resources/arduino-cli" ]; then
  CLI="/Applications/Arduino IDE.app/Contents/Resources/app/lib/backend/resources/arduino-cli"
else
  echo "Could not find arduino-cli. Install Arduino CLI or Arduino IDE 2.x, then ensure arduino-cli is on PATH." >&2
  exit 1
fi

exec "$CLI" "$@" --config-file "$CONFIG_FILE"
